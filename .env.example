# =============================================================================
# Shared — used by multiple binaries
# =============================================================================

# Solana cluster (bookkeeper, trade-keeper, event-keeper)
CLUSTER_RPC_URL=
CLUSTER_WS_URL=

# ClickHouse connection (event-keeper, read-api)
CLICKHOUSE_URL=
CLICKHOUSE_DATABASE=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# ClickHouse table names (event-keeper, read-api)
CLICKHOUSE_MARKET_UPDATES_TABLE=
CLICKHOUSE_CLOSE_POSITIONS_TABLE=

# =============================================================================
# bookkeeper
# =============================================================================

PAYER_KEYPAIR=
MARKET_ID=
SLOTS_BETWEEN_UPDATES=

# Optional robustness / rate-limit tuning
BOOKKEEPER_MIN_UPDATE_DELAY_MS=
BOOKKEEPER_SEND_RETRY_ATTEMPTS=
BOOKKEEPER_RETRY_INITIAL_DELAY_MS=
BOOKKEEPER_RETRY_MAX_DELAY_MS=
BOOKKEEPER_MAX_IDLE_SLEEP_MS=
BOOKKEEPER_ESTIMATED_SLOT_DURATION_MS=

# =============================================================================
# event-keeper
# =============================================================================

# Alternative to DATABASE_URL — password-only; constructs connection string internally
DATABASE_PASSWORD=

# ClickHouse write tuning
CLICKHOUSE_CHANNEL_CAPACITY=
CLICKHOUSE_BATCH_SIZE=
CLICKHOUSE_FLUSH_INTERVAL_MS=

# =============================================================================
# read-api
# =============================================================================

# Override shared CLICKHOUSE_* vars for read-api only
READ_API_CLICKHOUSE_DATABASE=
READ_API_CLICKHOUSE_USER=
READ_API_CLICKHOUSE_PASSWORD=

# Override shared DATABASE_URL for read-api only
READ_API_CONFIG_DATABASE_URL=

# ClickHouse table names (read-api only)
CLICKHOUSE_CANDLES_1M_TABLE=

# Server binding — falls back to PORT, then 0.0.0.0:8080
READ_API_BIND_ADDR=
PORT=

# Cache / polling tuning
READ_API_MARKET_CONFIG_CACHE_TTL_SECS=
READ_API_PRICE_STREAM_POLL_MS=
